{
  "ConnectionStrings": {
    "DefaultConnection_old": "Server=(localdb)\\MSSQLLocalDB;Database=GloboTicketShoppingBasketDb;Trusted_Connection=True;MultipleActiveResultSets=true",
    "DefaultConnection": "Data Source=GloboTicketShoppingBasketDb.db",
    "RedisConnection": ""
  },
  "CacheDurationMinutes": "10",
  "ShoppingBasket": {
    "CacheMode": "AzureRedis"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ServiceBusConnectionString": "",
  "PriceUpdatedMessageTopic": "priceupdatedmessage",
  "subscriptionName": "globoticketshoppingbasket",
  "AllowedHosts": "*",    
  "ApiConfigs": {
    "EventCatalog": {
      "Uri": "https://localhost:5001"
    },
    "Discount": {
      "Uri": "https://localhost:5007",
      "UseGrpc": false
    }    
  },  
  "Identity": {
    "Authority": "https://localhost:5020",
    "ClientCredentials": {      
      "EventCatalog": {        
        "Scope": "eventcatalog.read"
      },
      "Discount": {        
        "Scope": "discount.fullaccess"
      }
    },
    "TokenExchange": {      
      "Scopes": {
        "Discount": "discount.fullaccess",
        "Ordering": "ordering.fullaccess"
      }
    }
  },
  "JwtOptions": {
    "Authority": "https://localhost:5020",
    "RequireHttpsMetadata": true,
    "Audience": "shoppingbasket",
    "RequiredScope": "shoppingbasket.fullaccess"
  }  
}