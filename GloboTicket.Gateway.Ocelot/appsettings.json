{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",  
  "Identity": {    
    "TokenExchange": {      
      "Scopes": {
        "ShoppingBasket": "openid profile shoppingbasket.fullaccess",
        "EventCatalogRead": "openid profile eventcatalog.read",
        "EventCatalogWrite": "openid profile eventcatalog.write"
      }
    }
  },
  "JwtOptions": {
    "Authority": "https://localhost:5020",
    "RequireHttpsMetadata": true,
    "Audience": "globoticketgateway",
    "RequiredScope": "globoticketgateway.fullaccess"
  }
}